interface:
  version:
    major: 1
    minor: 0

import common/climate.sidl

ClimateZoneState: struct
  zone: ClimateZone
  temp: Int32
  fan: Int32

property climateState: ClimateZoneState

notification climateApplied(zone: ClimateZone, temp: Int32, fan: Int32)

method applyState(zone: ClimateZone, temp: Int32, fan: Int32) -> ok: Boolean
method frame() -> text: String
