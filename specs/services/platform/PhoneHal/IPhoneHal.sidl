interface:
  version:
    major: 1
    minor: 0

import common/contacts.sidl

PhoneCallState: enum
  idle
  ringing
  active
  ended

property phoneState: PhoneCallState
property phoneCaller: String
property contactsList: list<Contact>

notification phoneStateChanged(state: PhoneCallState, caller: String)

method simulateIncoming(caller: String) -> ok: Boolean
method accept() -> ok: Boolean
method end() -> ok: Boolean
method frame() -> text: String
